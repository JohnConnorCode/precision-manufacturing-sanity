# Sanity Configuration (Required)
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_VERSION=2025-01-01

# Sanity Tokens
# Use least privilege in production. If you only have one token, you can set it to both.
# - SANITY_READ_TOKEN: enables reading drafts (preview)
# - SANITY_WRITE_TOKEN: enables scripts/admin routes to create/update/delete content
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=

# Preview mode secret used by /api/preview route
NEXT_PUBLIC_PREVIEW_SECRET_TOKEN=

# Site Configuration (Recommended for Production)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Google Analytics (Optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Email / SMTP (Required for contact form)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-smtp-password-or-api-key
COMPANY_EMAIL=contact@your-company.com
